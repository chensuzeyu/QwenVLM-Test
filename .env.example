# Copy to .env and fill in. Never commit .env.
#
# =============================================================================
# 推荐：团队 Qwen Proxy（OpenAI 兼容，一条入口切换 EAS / DashScope）
# =============================================================================
# 示例：BASE 已含 /v1，程序会请求 {PROXY_BASE_URL}/chat/completions
PROXY_BASE_URL=http://127.0.0.1:5018/v1
PROXY_API_KEY=your_proxy_key_here
# Proxy 示例里多为「Authorization: <key>」无 Bearer；若网关要求 Bearer，设为 1
# PROXY_AUTH_BEARER=0
# 默认后端：eas（路演优先）| dashscope（备份）
PROXY_DEFAULT_BACKEND=dashscope
# 默认模型须与 backend 匹配：eas 仅 Qwen3.5-397B-A17B；dashscope 见 README 列表
PROXY_MODEL=Qwen3.5-397B-A17B

# =============================================================================
# 可选：直连阿里云 PAI-EAS（不设置 PROXY_BASE_URL 时走此模式）
# =============================================================================
# EAS_BASE_URL=http://1054059136692489.cn-beijing.pai-eas.aliyuncs.com/api/predict/qwen3_5_vllm
# EAS_API_TOKEN=your_eas_token_here
# EAS_MODEL=Qwen3.5-397B-A17B

# 超时（秒），两种模式共用
# LLM_TIMEOUT_S=120
